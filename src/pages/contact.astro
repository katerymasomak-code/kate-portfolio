---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { social } from "../config";

const links = [
    {
        name: "threads" as const,
        label: "Threads",
        handle: "@xpemixia",
        href: social.threads,
    },
    {
        name: "github" as const,
        label: "GitHub",
        handle: "@katerymasomak-code",
        href: social.github,
    },
];
---

<Layout
    title="Contact"
    description="Ways to follow new work and get in touch."
>
    <article class="page prose">
        <h1 class="page__title">Контакти</h1>
        <p class="lede">Контакти для зв'язку:</p>

        <ul class="contact-list">
            {
                links.map((link) => (
                    <li>
                        <a
                            class="contact-card"
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <span class="contact-card__icon">
                                <Icon name={link.name} />
                            </span>
                            <span class="contact-card__text">
                                <span class="contact-card__label">
                                    {link.label}
                                </span>
                                <span class="contact-card__handle">
                                    {link.handle}
                                </span>
                            </span>
                            <span
                                class="contact-card__arrow"
                                aria-hidden="true"
                            >
                                →
                            </span>
                        </a>
                    </li>
                ))
            }
        </ul>

        <p>
            <a class="text-link" href=`${import.meta.env.BASE_URL}/license`>Умови використання →</a>
        </p>
        <p>
            <a class="text-link" href=`${import.meta.env.BASE_URL}/privacy`>Політика конфіденційності →</a>
        </p>
    </article>
</Layout>
