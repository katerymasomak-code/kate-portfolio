---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: | CollectionEntry<'projects'>;
  base: string; // section URL prefix, e.g. "/blog/tech"
}
const { post, base } = Astro.props;

const href = `${base}/${post.id}`;
const date = new Date(post.data.pubDate);
const dateLabel = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const dateISO = date.toISOString().slice(0, 10);
---

<li class="post-card">
  <a class="post-card__link" href={href}>
    {/* Left Side: Image rendered first in the DOM */}
    {post.data.cover && (
      <div class="post-card__image-wrapper">
        <Image 
          src={post.data.cover} 
          alt={post.data.title} 
          class="post-card__image"
          width={300} 
          height={200} 
        />
      </div>
    )}

    {/* Right Side: Text Content */}
    <div class="post-card__content">
      <h2 class="post-card__title">{post.data.title}</h2>
      
      <p class="post-card__excerpt">{post.data.description}</p>

      <p class="post-card__meta">
        <time datetime={dateISO}>{dateLabel}</time>
      </p>
      
      {post.data.tags && post.data.tags.length > 0 && (
        <ul class="post-card__tags" aria-label="Tags">
          {post.data.tags.map((t) => (
            <li class="tag">{t}</li>
          ))}
        </ul>
      )}
    </div>
  </a>
</li>
